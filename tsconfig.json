{
    "compilerOptions": {
        "module": "Node16",
        "target": "ES2022",
        "outDir": "out",
        "lib": ["ES2022"],
        "sourceMap": true,
        "rootDir": "src",
        "strict": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "moduleResolution": "Node16",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "baseUrl": ".",
        "paths": {
            "@core/*": ["src/core/*"],
            "@config/*": ["src/config/*"],
            "@shared/*": ["src/shared/*"],
            "@providers/*": ["src/providers/*"],
            "@utils/*": ["src/utils/*"],
            "@webview/*": ["src/webview/*"]
        }
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", ".vscode-test", "webview-ui", "test"]
}
